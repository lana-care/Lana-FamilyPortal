# App environment — controls secure cookie flag (set to "production" in prod)
NODE_ENV=development

# Supabase (anon key — family portal is token-scoped via backend API)
SUPABASE_URL=
SUPABASE_KEY=
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=

# NestJS API (family portal data + feedback)
NUXT_PUBLIC_API_URL=http://localhost:4000
